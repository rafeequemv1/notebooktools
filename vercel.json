{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": null,
  "outputDirectory": "website",
  "trailingSlash": false,
  "cleanUrls": true,
  "redirects": [
    { "source": "/website", "destination": "/", "permanent": true },
    { "source": "/website/", "destination": "/", "permanent": true },
    { "source": "/website/:path*", "destination": "/:path*", "permanent": true }
  ]
}
