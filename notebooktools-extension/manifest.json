{
  "manifest_version": 3,
  "name": "NotebookTools",
  "version": "0.1.0",
  "description": "Save selected text and webpages into simple notebooks for NotebookLM workflows.",
  "permissions": ["activeTab", "contextMenus", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "NotebookTools",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://m.youtube.com/*",
        "https://youtu.be/*",
        "https://www.youtube-nocookie.com/*"
      ],
      "css": ["youtube-button.css"],
      "js": ["youtube-button.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "youtube-import.html",
        "youtube-import.js",
        "notebooklm-client.js",
        "storage.js",
        "shared.css"
      ],
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://m.youtube.com/*",
        "https://youtu.be/*",
        "https://www.youtube-nocookie.com/*"
      ]
    }
  ]
}
