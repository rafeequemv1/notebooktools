{
  "manifest_version": 3,
  "name": "NotebookTools — Import to NotebookLM",
  "version": "0.2.3",
  "description": "Import YouTube videos, X posts, webpages, and selected text into NotebookLM — one click from watch pages, popup, or right-click.",
  "permissions": ["activeTab", "storage", "contextMenus", "tabs"],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "NotebookTools — Import to NotebookLM",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://m.youtube.com/*",
        "https://youtu.be/*",
        "https://www.youtube-nocookie.com/*"
      ],
      "css": ["youtube-button.css"],
      "js": [
        "youtube-inject.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "css": ["platform-button.css"],
      "js": ["platform-extractors.js", "platform-button.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "youtube-import.html",
        "youtube-import.js",
        "platform-import.html",
        "platform-import.js",
        "notebooklm-client.js",
        "notebook-picker.js",
        "utils.js",
        "shared.css",
        "logo.png",
        "icons/icon16.png",
        "icons/icon48.png",
        "welcome.html"
      ],
      "matches": [
        "https://*/*",
        "http://*/*"
      ]
    }
  ]
}
