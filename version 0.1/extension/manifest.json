{
  "manifest_version": 3,
  "name": "NotebookTools — YouTube to NotebookLM",
  "version": "0.1.0",
  "description": "Import YouTube videos into NotebookLM notebooks with one click from the popup or an in-page button.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://m.youtube.com/*",
    "https://youtu.be/*",
    "https://www.youtube-nocookie.com/*",
    "https://notebooklm.google.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "NotebookTools — YouTube to NotebookLM",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://m.youtube.com/*",
        "https://youtu.be/*",
        "https://www.youtube-nocookie.com/*"
      ],
      "css": ["youtube-button.css"],
      "js": ["youtube-button.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "youtube-import.html",
        "youtube-import.js",
        "notebooklm-client.js",
        "utils.js",
        "shared.css"
      ],
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://m.youtube.com/*",
        "https://youtu.be/*",
        "https://www.youtube-nocookie.com/*"
      ]
    }
  ]
}
